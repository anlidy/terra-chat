# Generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# Instructions to create a Vercel Blob Store here: https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# Instructions to create a PostgreSQL database here: https://vercel.com/docs/postgres
POSTGRES_URL=****

# Encryption key for custom provider API keys (AES-256-GCM)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=****

# LlamaCloud API key for document parsing (PDF, DOCX, XLSX, PPTX, TXT)
# Get from: https://cloud.llamaindex.ai
LLAMA_CLOUD_API_KEY=****

# Image generation API (SiliconFlow FLUX by default)
# Get from: https://siliconflow.cn
IMAGE_GEN_API_KEY=****
IMAGE_GEN_BASE_URL=https://api.siliconflow.cn

# Zhipu AI API key for embeddings (embedding-3 model)
# Get from: https://open.bigmodel.cn
ZHIPU_API_KEY=****

# DashScope API key for RAG reranking (gte-rerank model)
# Get from: https://dashscope.console.aliyun.com/
# Pricing: https://help.aliyun.com/document_detail/2712518.html
DASHSCOPE_API_KEY=****

# Tavily API key for web search
# Get from: https://tavily.com
TAVILY_API_KEY=****
